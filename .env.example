# ============================================================
# Gausso Backend - Örnek Ortam Değişkenleri (.env şablonu)
# ============================================================
# Bu dosyayı ".env" olarak kopyalayın ve değerleri doldurun.
# ASLA gerçek .env dosyasını Git'e commit etmeyin!
# ============================================================

# Uygulama
APP_NAME="Gausso API"
APP_VERSION="0.1.0"
DEBUG=True
ENVIRONMENT=development

# Veritabanı
# Geliştirme (SQLite):
DATABASE_URL="sqlite+aiosqlite:///./gausso_dev.db"
# Üretim (PostgreSQL):
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/gausso_db"

# Güvenlik - ÜRETİMDE MUTLAKA DEĞİŞTİRİN!
# Güçlü bir key üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_A_STRONG_RANDOM_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
